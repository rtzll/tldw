#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
usage:
  tunnel-launchd install <label> <keychain-service> <tunnel-client> <profile> <repo-dir> <mcp-command> <mcp-host> <mcp-port>
  tunnel-launchd uninstall <label>
  tunnel-launchd restart <label>
  tunnel-launchd status <label>
  tunnel-launchd logs [--tail]
  tunnel-launchd run <keychain-service> <tunnel-client> <profile> <mcp-command> <mcp-host> <mcp-port>
EOF
  exit 64
}

xml_escape() {
  local value="$1"
  value="${value//&/&amp;}"
  value="${value//</&lt;}"
  value="${value//>/&gt;}"
  printf '%s' "$value"
}

user_domain() {
  printf 'gui/%s' "$(/usr/bin/id -u)"
}

keychain_account() {
  /usr/bin/id -un
}

install_agent() {
  [[ $# -eq 8 ]] || usage

  local label="$1"
  local keychain_service="$2"
  local tunnel_client="$3"
  local profile="$4"
  local repo_dir="$5"
  local mcp_command="$6"
  local mcp_host="$7"
  local mcp_port="$8"
  local client

  case "$tunnel_client" in
    /*) client="$tunnel_client" ;;
    *) client="$repo_dir/$tunnel_client" ;;
  esac

  test -x "$client" || { echo "Install tunnel-client at $client or set TLDW_TUNNEL_CLIENT"; exit 1; }

  local account
  account="$(keychain_account)"
  if [[ -n "${CONTROL_PLANE_API_KEY:-}" ]]; then
    /usr/bin/security add-generic-password \
      -a "$account" \
      -s "$keychain_service" \
      -w "$CONTROL_PLANE_API_KEY" \
      -T /usr/bin/security \
      -U >/dev/null
    echo "Stored CONTROL_PLANE_API_KEY in Keychain service $keychain_service"
  elif ! /usr/bin/security find-generic-password -a "$account" -s "$keychain_service" -w >/dev/null 2>&1; then
    echo "Set CONTROL_PLANE_API_KEY=sk-... once before running this recipe"
    exit 1
  fi

  local plist="$HOME/Library/LaunchAgents/$label.plist"
  local log_dir="$HOME/Library/Logs/tldw"
  local script="$repo_dir/scripts/tunnel-launchd"
  mkdir -p "$(dirname "$plist")" "$log_dir"

  cat > "$plist" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>$(xml_escape "$label")</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>$(xml_escape "$script")</string>
    <string>run</string>
    <string>$(xml_escape "$keychain_service")</string>
    <string>$(xml_escape "$client")</string>
    <string>$(xml_escape "$profile")</string>
    <string>$(xml_escape "$mcp_command")</string>
    <string>$(xml_escape "$mcp_host")</string>
    <string>$(xml_escape "$mcp_port")</string>
  </array>
  <key>WorkingDirectory</key>
  <string>$(xml_escape "$repo_dir")</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
  </dict>
  <key>StandardOutPath</key>
  <string>$(xml_escape "$log_dir/tunnel.out.log")</string>
  <key>StandardErrorPath</key>
  <string>$(xml_escape "$log_dir/tunnel.err.log")</string>
</dict>
</plist>
EOF

  /usr/bin/plutil -lint "$plist" >/dev/null
  /bin/launchctl bootout "$(user_domain)" "$plist" >/dev/null 2>&1 || true
  /bin/launchctl bootstrap "$(user_domain)" "$plist"
  /bin/launchctl enable "$(user_domain)/$label"
  /bin/launchctl kickstart -k "$(user_domain)/$label"

  echo "Installed and started $label"
  echo "Logs: $log_dir/tunnel.out.log and $log_dir/tunnel.err.log"
}

uninstall_agent() {
  [[ $# -eq 1 ]] || usage

  local label="$1"
  local plist="$HOME/Library/LaunchAgents/$label.plist"
  /bin/launchctl bootout "$(user_domain)" "$plist" >/dev/null 2>&1 || true
  rm -f "$plist"
  echo "Removed $label"
}

restart_agent() {
  [[ $# -eq 1 ]] || usage

  local label="$1"
  /bin/launchctl kickstart -k "$(user_domain)/$label"
  echo "Restarted $label"
}

run_agent() {
  [[ $# -eq 6 ]] || usage

  local keychain_service="$1"
  local tunnel_client="$2"
  local profile="$3"
  local mcp_command="$4"
  local mcp_host="$5"
  local mcp_port="$6"
  local mcp_pid=""

  cleanup() {
    if [[ -n "$mcp_pid" ]] && kill -0 "$mcp_pid" >/dev/null 2>&1; then
      kill "$mcp_pid" >/dev/null 2>&1 || true
      wait "$mcp_pid" >/dev/null 2>&1 || true
    fi
  }

  wait_for_mcp() {
    local attempts=50
    local i

    for ((i = 0; i < attempts; i++)); do
      if (:</dev/tcp/"$mcp_host"/"$mcp_port") >/dev/null 2>&1; then
        return 0
      fi

      if ! kill -0 "$mcp_pid" >/dev/null 2>&1; then
        echo "tldw MCP server exited before $mcp_host:$mcp_port became reachable" >&2
        return 1
      fi

      sleep 0.2
    done

    echo "Timed out waiting for tldw MCP server on $mcp_host:$mcp_port" >&2
    return 1
  }

  if [[ -z "${CONTROL_PLANE_API_KEY:-}" ]]; then
    CONTROL_PLANE_API_KEY="$(
      /usr/bin/security find-generic-password \
        -a "$(keychain_account)" \
        -s "$keychain_service" \
        -w
    )"
    export CONTROL_PLANE_API_KEY
  fi

  trap 'cleanup' EXIT
  trap 'cleanup; exit 130' INT
  trap 'cleanup; exit 143' TERM

  MCP_HOST="$mcp_host" MCP_PORT="$mcp_port" /bin/bash -lc "exec $mcp_command --host \"\$MCP_HOST\" --port \"\$MCP_PORT\"" &
  mcp_pid="$!"
  wait_for_mcp

  local status=0
  "$tunnel_client" run --profile "$profile" || status=$?
  cleanup
  trap - EXIT INT TERM
  return "$status"
}

case "${1:-}" in
  install)
    shift
    install_agent "$@"
    ;;
  uninstall)
    shift
    uninstall_agent "$@"
    ;;
  restart)
    shift
    restart_agent "$@"
    ;;
  status)
    shift
    [[ $# -eq 1 ]] || usage
    /bin/launchctl print "$(user_domain)/$1"
    ;;
  logs)
    shift
    case "${1:-}" in
      "")
        tail -n 80 "$HOME/Library/Logs/tldw/tunnel.err.log" "$HOME/Library/Logs/tldw/tunnel.out.log"
        ;;
      --tail)
        [[ $# -eq 1 ]] || usage
        tail -f "$HOME/Library/Logs/tldw/tunnel.err.log" "$HOME/Library/Logs/tldw/tunnel.out.log"
        ;;
      *)
        usage
        ;;
    esac
    ;;
  run)
    shift
    run_agent "$@"
    ;;
  *)
    usage
    ;;
esac
